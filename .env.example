# ============================================================================
# dbt-watsonx-spark Catalog Test Automation Configuration
# ============================================================================
# Copy this file to .env and fill in your actual values
# cp .env.example .env

# ============================================================================
# DEPLOYMENT TYPE
# ============================================================================
# Options: 'saas' (IBM Cloud) or 'cpd' (Cloud Pak for Data)
DEPLOYMENT_TYPE=saas

# Lakehouse API Version: 'v2' or 'v3' (default: v3)
# Use v3 for newer deployments, v2 for older ones if needed
LAKEHOUSE_API_VERSION=v3

# ============================================================================
# PRE-EXISTING AUTHENTICATION (Optional)
# ============================================================================
# If you already have a valid token, provide it here to skip authentication
# This is useful when integrating with existing auth workflows
# AUTH_TOKEN=eyJhbGciOiJSUzI1NiIsInR5cCI6IkpXVCJ9...
# USERNAME=your-username

# ============================================================================
# UNIFIED CONFIGURATION (Works for both SaaS and CPD)
# ============================================================================

# Hostname/URL of your watsonx.data instance
# For SaaS: Just the hostname (e.g., wxd-instance.lakehouse.cloud.ibm.com)
# For CPD: Full URL with https:// (e.g., https://cpd-instance.apps.example.com)
WATSONX_HOSTNAME=your-instance-hostname-or-url

# API Key or Password
# For SaaS: IBM Cloud API Key (create at https://cloud.ibm.com/iam/apikeys)
# For CPD: Your CPD user password
WATSONX_APIKEY=your-api-key-or-password

# Instance ID (Required for both SaaS and CPD)
# For SaaS: Full CRN (e.g., crn:v1:bluemix:public:lakehouse:us-south:a/...)
# For CPD: Instance ID number (e.g., 1777813222451474)
WATSONX_INSTANCE_ID=your-instance-id

# Username (Only required for CPD, ignored for SaaS)
# For CPD: Your CPD username (e.g., admin)
# For SaaS: Leave empty or comment out
CPD_USERNAME=admin

# ============================================================================
# CATALOG CONFIGURATION
# ============================================================================

# Catalog names (will be created if they don't exist)
ICEBERG_CATALOG_NAME=iceberg_data
DELTA_CATALOG_NAME=delta_data
HUDI_CATALOG_NAME=hudi_data

# Enable/disable specific catalog types
# Set to 'false' to skip creating a catalog type
# Useful when only certain formats are available or needed
ICEBERG_CATALOG_ENABLED=true
DELTA_CATALOG_ENABLED=true
HUDI_CATALOG_ENABLED=true

# ============================================================================
# STORAGE BUCKET CONFIGURATION
# ============================================================================

# Storage bucket names for each catalog
# Buckets will be registered with lakehouse if they don't exist
# Leave empty to skip bucket registration for that catalog
ICEBERG_BUCKET=iceberg-dbt-test
DELTA_BUCKET=delta-dbt-test
HUDI_BUCKET=hudi-dbt-test

# S3-compatible storage credentials
# For SaaS: Optional (only if registering new buckets via lakehouse API)
# For CPD: REQUIRED (used by /api/v1/storages to create storage + catalog)
STORAGE_ENDPOINT=s3.us-south.cloud-object-storage.appdomain.cloud
STORAGE_REGION=us-south
STORAGE_ACCESS_KEY=your-hmac-access-key
STORAGE_SECRET_KEY=your-hmac-secret-key

# Note: CPD uses /api/v1/storages which creates storage and catalog together
# SaaS uses /lakehouse/api/v3/buckets and /lakehouse/api/v3/catalogs separately

# ============================================================================
# SPARK ENGINE CONFIGURATION
# ============================================================================

# Spark engine names (will be created if they don't exist)
SPARK_ENGINE_NAME=spark-dbt-test
SPARK_ENGINE_AUTHZ_NAME=spark-dbt-authz-test

# Spark version (default: 4.0)
# SPARK_VERSION=4.0

# CPD Volume Configuration for Spark Engine Home
# IMPORTANT: The API only accepts numeric instance_id, not cpd-instance:: format
#
# Option 1: Provide numeric volume instance ID directly (recommended for sharing)
# Get from: GET /lakehouse/api/v3/{instance_id}/cpd/spark_instances
# Response: {"volumes": [{"display_name": "cpd-instance::name", "instance_id": "123"}]}
# Example: SPARK_ENGINE_VOLUME_ID=1779014098842423
# SPARK_ENGINE_VOLUME_ID=

# Option 2: Specify volume name (script will look up its numeric instance_id)
# Script searches for volume with display_name "cpd-instance::<volume-name>"
# and extracts its numeric instance_id to use in the API call
SPARK_ENGINE_VOLUME_NAME=spark-engine-volume

# Volume creation settings (used only when creating new volume)
SPARK_ENGINE_VOLUME_SIZE=5Gi
SPARK_ENGINE_VOLUME_CLASS=nfs-client

# Note: Multiple engines can share the same volume by using the same numeric instance_id
# Note: The display_name format is "cpd-instance::<name>" but API requires numeric ID
# Note: SaaS uses different configuration (S3-based storage)

# ============================================================================
# QUERY SERVER CONFIGURATION (Optional)
# ============================================================================

# If you already have a running query server, provide its URL here
# This will skip all infrastructure setup (catalogs, engines, attachments)
# and go directly to running tests
# QUERY_SERVER_URL=https://your-query-server.example.com:8443

# Alternatively, set this flag to skip infrastructure setup
# SKIP_INFRASTRUCTURE=false

# ============================================================================
# TEST CONFIGURATION
# ============================================================================

# Python virtual environment path
# The script will activate this venv before running tests
PYTHON_VENV_PATH=~/projects/python-env/venv

# Test pattern (pytest path/pattern)
# Default runs all catalog tests
TEST_PATTERN=tests/functional/adapter/catalog_tests/

# Optional: Run specific test file
# TEST_PATTERN=tests/functional/adapter/catalog_tests/test_three_part_names.py

# Optional: Run specific test class
# TEST_PATTERN=tests/functional/adapter/catalog_tests/test_three_part_names.py::TestThreePartNames

# Optional: Run specific test method
# TEST_PATTERN=tests/functional/adapter/catalog_tests/test_three_part_names.py::TestThreePartNames::test_three_part_table_creation

# ============================================================================
# ADVANCED OPTIONS
# ============================================================================

# Test schema prefix (for isolation)
TEST_SCHEMA_PREFIX=dbt_test

# ============================================================================
# QUICK START EXAMPLES
# ============================================================================

# Example 1: IBM Cloud SaaS with full setup
# ------------------------------------------
# DEPLOYMENT_TYPE=saas
# WATSONX_HOSTNAME=wxd-12345.lakehouse.cloud.ibm.com
# WATSONX_APIKEY=your-ibm-cloud-api-key
# WATSONX_INSTANCE_ID=crn:v1:bluemix:public:lakehouse:us-south:a/...
# ICEBERG_CATALOG_ENABLED=true
# DELTA_CATALOG_ENABLED=true
# HUDI_CATALOG_ENABLED=true
# S3_ENDPOINT=https://s3.us-south.cloud-object-storage.appdomain.cloud
# S3_ACCESS_KEY=your-key
# S3_SECRET_KEY=your-secret

# Example 2: Cloud Pak for Data (CPD) with full setup
# ----------------------------------------------------
# DEPLOYMENT_TYPE=cpd
# WATSONX_HOSTNAME=https://cpd-cpd-instance.apps.ingestion-big04.cp.fyre.ibm.com
# WATSONX_APIKEY=your-cpd-password
# WATSONX_INSTANCE_ID=1777813222451474
# CPD_USERNAME=admin
# ICEBERG_CATALOG_ENABLED=true
# DELTA_CATALOG_ENABLED=true
# HUDI_CATALOG_ENABLED=true
# S3_ENDPOINT=https://s3.example.com
# S3_ACCESS_KEY=your-key
# S3_SECRET_KEY=your-secret

# Example 3: Use existing query server (skip infrastructure setup)
# ------------------------------------------------------------------
# DEPLOYMENT_TYPE=saas
# AUTH_TOKEN=your-existing-token
# USERNAME=admin
# QUERY_SERVER_URL=https://query-server.example.com:8443
# PYTHON_VENV_PATH=~/venv
# TEST_PATTERN=tests/functional/adapter/catalog_tests/

# Example 4: Test only Iceberg catalog with S3 bucket creation
# -------------------------------------------------------------
# DEPLOYMENT_TYPE=saas
# WATSONX_HOSTNAME=wxd-12345.lakehouse.cloud.ibm.com
# WATSONX_APIKEY=abc123...
# WATSONX_INSTANCE_ID=crn:v1:bluemix:...
# ICEBERG_CATALOG_ENABLED=true
# DELTA_CATALOG_ENABLED=false
# HUDI_CATALOG_ENABLED=false
# ICEBERG_BUCKET=my-iceberg-bucket
# S3_ENDPOINT=https://s3.us-south.cloud-object-storage.appdomain.cloud
# S3_ACCESS_KEY=your-key
# S3_SECRET_KEY=your-secret
# TEST_PATTERN=tests/functional/adapter/catalog_tests/test_three_part_names.py

# ============================================================================
# NOTES
# ============================================================================
# 1. Never commit the actual .env file with real credentials to version control
# 2. The .env file is in .gitignore by default
# 3. All catalog and engine resources will be created automatically
# 4. Existing resources will be reused (not recreated)
# 5. Set catalog_enabled=false to skip catalog types you don't need
# 6. Leave bucket names empty to skip bucket creation
# 7. Use AUTH_TOKEN to skip authentication if you already have a valid token